{
  "name": "dokassist",
  "version": "0.7.13",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "build:dmg": "pnpm tauri build --target aarch64-apple-darwin",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --write \"src/**/*.{js,ts,svelte,json,css}\"",
